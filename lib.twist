
// Простейшее макро выражение
#macro max(a, b) = if (a > b) {a} else {b}

global let Number = Int | Double;
let my_eq = lambda(global a: Number | String, global b: Number | String) -> Bool : namespace {
    static let eq: Bool = false;
    if (typeof(a) == String && typeof(b) == String) {
        eq = a == b;
    } else if (typeof(a) >> Number && typeof(b) >> Number) {
        eq = a == b;
    }
}::eq;