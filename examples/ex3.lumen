
func struct_gen(global a: Int, global b: Int) -> auto {
    struct Math {
        let c;
        func __init__(c: Int) -> typeof(Math) {
            this.c = c;
            ret this;
        }
        
        func call() -> Int {
            ret this.a + this.b + this.c;
        }
    }
    
    ret Math;
}

let MS_1 = struct_gen(10, 20);

outln MS_1(30).call();

outln struct_gen(10, 1)(5).call();