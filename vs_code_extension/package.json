{
  "name": "luman",
  "displayName": "Lumen",
  "description": "lumen support",
  "version": "0.0.8",
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "lumen",
      "aliases": ["Lumen", "lumen"],
      "extensions": [".twist"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "lumen",
      "scopeName": "source.lumen",
      "path": "./syntaxes/lumen.tmLanguage.json"
    }]
  }
}
