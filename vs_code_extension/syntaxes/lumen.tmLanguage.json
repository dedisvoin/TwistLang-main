{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Lumen",
	"patterns": [
		{
			"include": "#preprocessor"
		},
		{
			"include": "#struct-declaration"
		},
		{
			"include": "#function-declaration"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#input-keyword"
		},
		{
			"include": "#namespace-declaration"
		},
		{
			"include": "#namespace-resolution"
		},
		{
			"include": "#modifiers"
		},
		{
			"include": "#types"
		},
		{
			"include": "#literals"
		},
		{
			"include": "#function-call"
		},
		{
			"include": "#function-arguments"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#comments"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#object-access"
		},
		{
			"include": "#dot-punctuation"
		},
		{
			"include": "#identifiers"
		}
	],
	"repository": {
		"preprocessor": {
			"patterns": [
				{
					"include": "#define-directive"
				},
				{
					"include": "#macro-directive"
				},
				{
					"include": "#include-directive"
				}
			]
		},
		
		"struct-declaration": {
			"name": "meta.struct.declaration.lumen",
			"begin": "\\b(struct)\\b\\s+",
			"beginCaptures": {
				"1": {
					"name": "keyword.control.lumen"
				}
			},
			"end": "(?=\\}|\\r|\\n|$)",
			"patterns": [
				{
					"name": "entity.name.struct.lumen",
					"match": "[a-zA-Z_][a-zA-Z0-9_]*"
				},
				{
					"begin": "\\{",
					"end": "\\}",
					"beginCaptures": {
						"0": {
							"name": "punctuation.curly.open.lumen"
						}
					},
					"endCaptures": {
						"0": {
							"name": "punctuation.curly.close.lumen"
						}
					},
					"contentName": "meta.struct.body.lumen",
					"patterns": [
						{
							"include": "#preprocessor"
						},
						{
							"include": "#function-declaration"
						},
						{
							"include": "#keywords"
						},
						{
							"include": "#input-keyword"
						},
						{
							"include": "#namespace-declaration"
						},
						{
							"include": "#namespace-resolution"
						},
						{
							"include": "#modifiers"
						},
						{
							"include": "#types"
						},
						{
							"include": "#literals"
						},
						{
							"include": "#function-call"
						},
						{
							"include": "#function-arguments"
						},
						{
							"include": "#strings"
						},
						{
							"include": "#comments"
						},
						{
							"include": "#operators"
						},
						{
							"include": "#numbers"
						},
						{
							"include": "#struct-declaration"
						}
					]
				}
			]
		},
		
		"define-directive": {
			"name": "meta.preprocessor.define.lumen",
			"begin": "^\\s*(#define)\\s+",
			"beginCaptures": {
				"1": {
					"name": "keyword.control.directive.lumen"
				}
			},
			"end": "$",
			"patterns": [
				{
					"name": "entity.name.constant.lumen",
					"match": "[a-zA-Z_][a-zA-Z0-9_]*"
				},
				{
					"name": "keyword.operator.assignment.lumen",
					"match": "="
				},
				{
					"include": "#strings"
				},
				{
					"include": "#numbers"
				},
				{
					"include": "#literals"
				},
				{
					"include": "#function-call"
				},
				{
					"include": "#operators"
				}
			]
		},
		
		"macro-directive": {
			"name": "meta.preprocessor.macro.lumen",
			"begin": "^\\s*(#macro)\\s+",
			"beginCaptures": {
				"1": {
					"name": "keyword.control.directive.lumen"
				}
			},
			"end": "$",
			"patterns": [
				{
					"name": "entity.name.function.macro.lumen",
					"match": "[a-zA-Z_][a-zA-Z0-9_]*"
				},
				{
					"begin": "\\(",
					"end": "\\)",
					"contentName": "meta.function.parameters.lumen",
					"patterns": [
						{
							"name": "variable.parameter.lumen",
							"match": "[a-zA-Z_][a-zA-Z0-9_]*"
						},
						{
							"match": ","
						}
					]
				},
				{
					"name": "keyword.operator.assignment.lumen",
					"match": "="
				},
				{
					"include": "#strings"
				},
				{
					"include": "#numbers"
				},
				{
					"include": "#literals"
				},
				{
					"include": "#function-call"
				},
				{
					"include": "#operators"
				}
			]
		},
		
		"include-directive": {
			"name": "meta.preprocessor.include.lumen",
			"match": "^\\s*(#include)\\s+(\"[^\"]+\"|'[^']+'|[a-zA-Z_][a-zA-Z0-9_]*(?:::[a-zA-Z_][a-zA-Z0-9_]*)*)",
			"captures": {
				"1": {
					"name": "keyword.control.directive.lumen"
				},
				"2": {
					"patterns": [
						{
							"include": "#strings"
						},
						{
							"name": "entity.name.namespace.lumen",
							"match": "[a-zA-Z_][a-zA-Z0-9_]*(?:::[a-zA-Z_][a-zA-Z0-9_]*)*"
						}
					]
				}
			}
		},
		
		"function-declaration": {
			"name": "meta.function.declaration.lumen",
			"begin": "\\b(func)\\b\\s+",
			"beginCaptures": {
				"1": {
					"name": "keyword.control.lumen"
				}
			},
			"end": "(?=\\{|;|\\r|\\n)",
			"patterns": [
				{
					"name": "entity.name.function.lumen",
					"match": "[a-zA-Z_][a-zA-Z0-9_]*"
				},
				{
					"begin": "\\(",
					"end": "\\)",
					"contentName": "meta.function.parameters.lumen",
					"patterns": [
						{
							"match": ","
						},
						{
							"match": "="
						},
						{
							"name": "punctuation.separator.type.lumen",
							"match": ":"
						},
						{
							"name": "meta.type.annotation.lumen",
							"begin": "(?<=:)\\s*",
							"end": "(?=,|=\\s*|\\))",
							"patterns": [
								{
									"include": "source.lumen"
								}
							]
						},
						{
							"include": "#literals"
						},
						{
							"include": "#function-call"
						},
						{
							"include": "#strings"
						},
						{
							"include": "#comments"
						},
						{
							"include": "#numbers"
						},
						{
							"include": "#operators"
						},
						{
							"include": "source.lumen"
						}
					]
				},
				{
					"name": "meta.return.type.lumen",
					"begin": "\\s*(->)\\s*",
					"end": "(?=\\{|;|\\r|\\n)",
					"patterns": [
						{
							"include": "source.lumen"
						}
					]
				}
			]
		},
		
		"function-call": {
			"patterns": [{
				"name": "meta.function.call.lumen",
				"match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
				"captures": {
					"1": {
						"name": "entity.name.function.lumen"
					},
					"2": {
						"name": "punctuation.parenthesis.open.lumen"
					}
				}
			}]
		},
		
		"function-arguments": {
			"name": "meta.function.arguments.lumen",
			"begin": "\\(",
			"end": "\\)",
			"beginCaptures": {
				"0": {
					"name": "punctuation.parenthesis.open.lumen"
				}
			},
			"endCaptures": {
				"0": {
					"name": "punctuation.parenthesis.close.lumen"
				}
			},
			"patterns": [
				{
					"include": "source.lumen"
				}
			]
		},
		
		"keywords": {
			"patterns": [{
				"name": "keyword.control.lumen",
				"match": "\\b(for|while|let|in|and|or|if|else|ret|auto|assert|lambda|break|continue|out|outln|struct|exit)\\b"
			}]
		},
		
		"input-keyword": {
			"patterns": [{
				"name": "support.function.input.lumen",
				"match": "\\b(input|typeof|sizeof|exit)\\b"
			}]
		},
		
		"namespace-declaration": {
			"name": "meta.namespace.declaration.lumen",
			"begin": "\\b(namespace)\\b\\s+",
			"beginCaptures": {
				"1": {
					"name": "keyword.control.lumen"
				}
			},
			"end": "(?=\\s*\\{|\\r|\\n|$)",
			"patterns": [
				{
					"name": "entity.name.namespace.lumen",
					"match": "[a-zA-Z_][a-zA-Z0-9_]*(?:::[a-zA-Z_][a-zA-Z0-9_]*)*"
				}
			]
		},
		
		"namespace-resolution": {
			"patterns": [
				{
					"match": "([a-zA-Z_][a-zA-Z0-9_]*)(::)",
					"captures": {
						"1": {
							"name": "entity.name.namespace.lumen"
						},
						"2": {
							"name": "punctuation.separator.namespace.lumen"
						}
					}
				}
			]
		},
		
		"modifiers": {
			"name": "storage.modifier.lumen",
			"match": "\\b(global|static|const|final|private)\\b"
		},
		
		"types": {
			"patterns": [
				{
					"name": "storage.type.builtin.lumen",
					"match": "\\b(Int|Bool|String|Char|Null|Double|Void|Namespace|Lambda|Func|Type|ptr)\\b"
				}
			]
		},
		
		"literals": {
			"patterns": [{
				"name": "constant.language.lumen",
				"match": "\\b(true|false|null|new|del)\\b"
			}]
		},
		
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.integer.lumen",
					"match": "\\b\\d+\\b"
				},
				{
					"name": "constant.numeric.float.lumen",
					"match": "\\b\\d+\\.\\d+\\b"
				},
				{
					"name": "constant.numeric.float.lumen",
					"match": "\\b\\d*\\.\\d+\\b"
				}
			]
		},
		
		"operators": {
			"name": "keyword.operator.lumen",
			"match": "[+\\-*/%=&|^!<>~?]+"
		},
		
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.lumen",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.lumen",
							"match": "\\\\(x\\h{2}|[0-2][0-7]{0,2}|3[0-6][0-7]?|37[0-7]?|[4-7][0-7]?|.)"
						}
					]
				},
				{
					"name": "string.quoted.single.lumen",
					"begin": "'",
					"end": "'",
					"patterns": [
						{
							"name": "constant.character.escape.lumen",
							"match": "\\\\(x\\h{2}|[0-2][0-7]{0,2}|3[0-6][0-7]?|37[0-7]?|[4-7][0-7]?|.)"
						}
					]
				}
			]
		},
		
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.lumen",
					"begin": "//",
					"end": "$"
				},
				{
					"name": "comment.block.lumen",
					"begin": "/\\*",
					"end": "\\*/"
				}
			]
		},
		
		"object-access": {
			"name": "meta.object.access.lumen",
			"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\.)",
			"captures": {
				"1": {
					"name": "constant.regexp"
				},
				"2": {
					"name": "punctuation.separator.dot.lumen"
				}
			}
		},
		
		"dot-punctuation": {
			"match": "\\.",
			"name": "punctuation.separator.dot.lumen"
		},
		
		"identifiers": {
			"match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
			"name": "variable.other.lumen"
		}
	},
	"scopeName": "source.lumen"
}